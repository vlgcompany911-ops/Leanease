<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnEase Pro - AI Integrated</title>
    <link rel="icon" type="image/jpeg" href="logo.jpg">
    <style>
        :root { --primary: #2563eb; --secondary: #64748b; --success: #10b981; --bg: #f8fafc; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; color: #1e293b; }
        .hidden { display: none !important; }
        
        /* Dashboard Layout */
        header { background: white; padding: 1rem 5%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e2e8f0; }
        .db-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; padding: 20px; max-width: 1000px; margin: auto; }
        .db-card { padding: 25px 15px; border-radius: 18px; color: white; cursor: pointer; transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .db-card:active { transform: scale(0.95); }

        /* Micro AI Floating Button */
        #aiTrigger { position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; background: var(--primary); border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; cursor: pointer; box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4); z-index: 9999; border: none; }
        
        /* AI Chat Box */
        #aiWindow { position: fixed; bottom: 90px; right: 20px; width: 320px; height: 450px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); flex-direction: column; z-index: 10000; overflow: hidden; display: none; }
        .ai-header { background: var(--primary); color: white; padding: 15px; font-weight: bold; display: flex; justify-content: space-between; }
        .ai-messages { flex-grow: 1; padding: 15px; overflow-y: auto; font-size: 0.9rem; }
        .ai-input-area { padding: 10px; border-top: 1px solid #eee; display: flex; gap: 5px; }
        input[type="text"] { flex-grow: 1; border: 1px solid #ddd; border-radius: 20px; padding: 8px 15px; outline: none; }

        .bg-blue { background: #3b82f6; } .bg-purple { background: #a855f7; } .bg-orange { background: #f97316; } .bg-green { background: #10b981; }
    </style>
</head>
<body>

    <div id="dashboardPage">
        <header>
            <div style="font-weight:bold;">LearnEase Pro</div>
            <div id="status" style="color:var(--success); font-size:0.8rem;">● Online</div>
        </header>

        <div class="db-grid">
            <div class="db-card bg-blue" onclick="startMode('Exam')"><h4>🏆 Exam</h4><p>Timed</p></div>
            <div class="db-card bg-purple" onclick="startMode('Practice')"><h4>📝 Practice</h4><p>Feedback</p></div>
            <div class="db-card bg-orange" onclick="startMode('Study')"><h4>📖 Study</h4><p>Untimed</p></div>
            <div class="db-card bg-green" onclick="startMode('History')"><h4>📊 History</h4><p>Results</p></div>
        </div>
    </div>

    <button id="aiTrigger" onclick="toggleAI()">🤖</button>

    <div id="aiWindow">
        <div class="ai-header">
            <span>Micro AI Tutor</span>
            <span style="cursor:pointer;" onclick="toggleAI()">×</span>
        </div>
        <div class="ai-messages" id="aiMsgs">
            <div style="background:#f1f5f9; padding:10px; border-radius:10px; margin-bottom:10px;">Hello Victory! Need help with GET 205 Fluid Mechanics?</div>
        </div>
        <div class="ai-input-area">
            <input type="text" id="aiQuery" placeholder="Ask a question...">
            <button onclick="askAI()" style="background:var(--primary); color:white; border:none; border-radius:50%; width:35px; height:35px; cursor:pointer;">&rarr;</button>
        </div>
    </div>

    <script>
        // 1. DASHBOARD MODE HANDLER
        function startMode(mode) {
            console.log("Starting " + mode);
            alert("Entering " + mode + " Mode. Loading academic questions...");
        }

        // 2. MICRO AI LOGIC
        function toggleAI() {
            const win = document.getElementById('aiWindow');
            win.style.display = (win.style.display === 'flex') ? 'none' : 'flex';
        }

        function askAI() {
            const q = document.getElementById('aiQuery').value;
            if(!q) return;

            const msgDiv = document.getElementById('aiMsgs');
            msgDiv.innerHTML += `<div style="text-align:right; margin-bottom:10px;"><span style="background:var(--primary); color:white; padding:8px 12px; border-radius:12px; display:inline-block;">${q}</span></div>`;
            
            document.getElementById('aiQuery').value = '';

            setTimeout(() => {
                msgDiv.innerHTML += `<div style="text-align:left; margin-bottom:10px;"><span style="background:#f1f5f9; padding:8px 12px; border-radius:12px; display:inline-block;">Analyzing your question about "${q}"... I'm looking into your GET 205 materials now.</span></div>`;
                msgDiv.scrollTop = msgDiv.scrollHeight;
            }, 1000);
        }

        // Check Session
        window.onload = () => {
            console.log("LearnEase v23.0 Ready");
        };
    </script>
</body>
</html>
